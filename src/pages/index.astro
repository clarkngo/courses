---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCourses = await getCollection('courses');
const allLessons = await getCollection('lessons');
const base = import.meta.env.BASE_URL;

const courses = allCourses.sort((a, b) => {
  const statusOrder = (s: string) => s === 'available' ? 0 : 1;
  return statusOrder(a.data.status) - statusOrder(b.data.status) || a.data.order - b.data.order;
});

// Count lessons per course (slug starts with courseSlug/)
function lessonCount(courseSlug: string) {
  return allLessons.filter(l => l.slug.startsWith(courseSlug + '/')).length;
}

const availableCount = courses.filter(c => c.data.status === 'available').length;
const totalCount = courses.length;
---

<BaseLayout title="Course Catalog" description="Master AI, web development, data science, and more — all built for complete beginners.">
  <div class="min-h-screen bg-gray-50">

    <!-- ── Nav ──────────────────────────────────────── -->
    <nav class="bg-white border-b border-gray-200 px-6 py-3 flex items-center justify-between sticky top-0 z-10">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold text-sm">C</div>
        <span class="font-bold text-gray-900">Clark's Courses</span>
      </div>
      <div class="text-sm text-gray-500">
        {availableCount} of {totalCount} courses available
      </div>
    </nav>

    <!-- ── Hero ─────────────────────────────────────── -->
    <section class="bg-gradient-to-br from-brand-700 via-brand-600 to-brand-500 text-white px-6 py-20">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-brand-200 text-sm font-semibold uppercase tracking-widest mb-4">
          Learn at your own pace
        </p>
        <h1 class="text-4xl sm:text-5xl font-bold mb-5 leading-tight">
          Skills That Move the World Forward
        </h1>
        <p class="text-brand-100 text-lg max-w-2xl mx-auto mb-8 leading-relaxed">
          Practical short courses on AI, technology, and the skills that matter —
          built for complete beginners, taught with real-world examples.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <span class="bg-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full">🤖 Physical AI</span>
          <span class="bg-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full">🚨 First Responders</span>
          <span class="bg-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full">🛡️ Secure AI</span>
          <span class="bg-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full">💻 Web Dev</span>
          <span class="bg-white/20 text-white text-sm font-medium px-4 py-1.5 rounded-full">🧠 LLMs</span>
        </div>
      </div>
    </section>

    <!-- ── Course Catalog ────────────────────────────── -->
    <section class="max-w-6xl mx-auto px-6 py-16">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">All Courses</h2>
          <p class="text-gray-500 mt-1">{totalCount} courses · built for complete beginners</p>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-brand-500 inline-block"></span>
          <span class="text-sm text-gray-500">Available</span>
          <span class="w-3 h-3 rounded-full bg-gray-300 inline-block ml-3"></span>
          <span class="text-sm text-gray-500">Coming soon</span>
        </div>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {courses.map(course => {
          const count = lessonCount(course.slug);
          const isAvailable = course.data.status === 'available';
          const href = isAvailable ? `${base}courses/${course.slug}/` : undefined;

          return (
            <div
              class={`module-card flex flex-col group ${isAvailable ? 'cursor-pointer' : 'opacity-75'}`}
              style={isAvailable ? `--card-color: ${course.data.color}` : ''}
            >
              <!-- Card top accent bar -->
              {isAvailable && (
                <div
                  class="h-1 rounded-t-2xl -mt-6 -mx-6 mb-5"
                  style={`background-color: ${course.data.color}`}
                ></div>
              )}

              <!-- Icon + status -->
              <div class="flex items-start justify-between mb-3">
                <span class="text-4xl">{course.data.icon}</span>
                {isAvailable ? (
                  <span class="text-xs font-bold px-2.5 py-1 rounded-full bg-green-100 text-green-700">
                    ✓ Available
                  </span>
                ) : (
                  <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-gray-100 text-gray-500">
                    Coming Soon
                  </span>
                )}
              </div>

              <!-- Title + description -->
              <h3 class={`text-lg font-bold mb-2 ${isAvailable ? 'text-gray-900 group-hover:text-brand-700 transition-colors' : 'text-gray-600'}`}>
                {course.data.title}
              </h3>
              <p class="text-sm text-gray-500 leading-relaxed flex-1 mb-5">
                {course.data.description}
              </p>

              <!-- Meta + CTA -->
              <div class="flex items-center justify-between mt-auto pt-4 border-t border-gray-100">
                <span class="text-xs text-gray-400">
                  {isAvailable && count > 0 ? `${count} lesson${count !== 1 ? 's' : ''}` : '🔒 In development'}
                </span>
                {isAvailable ? (
                  <a href={href} class="btn-primary text-xs py-1.5 px-4">
                    Start Course →
                  </a>
                ) : (
                  <span class="text-xs text-gray-400 font-medium">Notify me</span>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- ── Footer ────────────────────────────────────── -->
    <footer class="border-t border-gray-200 py-8 text-center text-sm text-gray-400">
      Built with Astro · Deployed on GitHub Pages
    </footer>
  </div>
</BaseLayout>
