---
import { getCollection } from 'astro:content';
import LessonLayout from '../../../layouts/LessonLayout.astro';

export async function getStaticPaths() {
  const allLessons = await getCollection('lessons');
  return allLessons.map(entry => {
    const [courseSlug, ...rest] = entry.slug.split('/');
    const lessonSlug = rest.join('/');
    return {
      params: { courseSlug, slug: lessonSlug },
      props: { entry, courseSlug },
    };
  });
}

const { entry, courseSlug } = Astro.props;
const { Content } = await entry.render();

// Get course metadata for display
const allCourses = await getCollection('courses');
const course = allCourses.find(c => c.slug === courseSlug);
---

<LessonLayout
  title={entry.data.title}
  description={entry.data.description}
  module={entry.data.module}
  moduleTitle={entry.data.moduleTitle}
  lesson={entry.data.lesson}
  duration={entry.data.duration}
  youtubeId={entry.data.youtubeId}
  courseSlug={courseSlug}
  courseTitle={course?.data.title ?? courseSlug}
  courseColor={course?.data.color ?? '#3b63f5'}
  slug={entry.slug}
>
  <Content />
</LessonLayout>
