---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import { getCollection } from 'astro:content';

export interface Props {
  title: string;
  description?: string;
  module: number;
  moduleTitle: string;
  lesson: number;
  duration?: string;
  youtubeId?: string;
  courseSlug: string;
  courseTitle: string;
  courseColor?: string;
  slug: string;
}

const {
  title,
  description,
  module: moduleNum,
  moduleTitle,
  lesson: lessonNum,
  duration,
  youtubeId,
  courseSlug,
  courseTitle,
  courseColor = '#3b63f5',
  slug,
} = Astro.props;

const allLessons = await getCollection('lessons');
const courseLessons = allLessons
  .filter(l => l.slug.startsWith(courseSlug + '/'))
  .sort((a, b) => a.data.module - b.data.module || a.data.lesson - b.data.lesson);

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${title} | ${courseTitle}`} description={description}>
  <div class="flex h-screen overflow-hidden bg-gray-50">

    <!-- ── Sidebar ─────────────────────────────────── -->
    <Sidebar
      courseLessons={courseLessons}
      currentSlug={slug}
      courseSlug={courseSlug}
      courseTitle={courseTitle}
      courseColor={courseColor}
    />

    <!-- ── Main content ───────────────────────────── -->
    <main class="flex-1 overflow-y-auto">

      <!-- Top bar -->
      <header class="sticky top-0 z-10 bg-white border-b border-gray-200 px-4 sm:px-6 md:px-8 py-3 flex items-center justify-between gap-2">
        <div class="flex items-center gap-2 text-sm text-gray-500 min-w-0">
          <button
            type="button"
            id="sidebar-toggle"
            class="md:hidden -ml-1.5 flex-shrink-0 p-1.5 text-gray-500 hover:text-gray-800 rounded-lg hover:bg-gray-100"
            aria-label="Open lesson menu"
          >
            <span class="text-lg leading-none">☰</span>
          </button>
          <a href={base} class="hidden sm:inline hover:text-brand-600 font-medium flex-shrink-0">Home</a>
          <span class="hidden sm:inline">›</span>
          <a href={`${base}${courseSlug}/`} class="hidden sm:inline hover:text-brand-600 flex-shrink-0 truncate max-w-[120px]">{courseTitle}</a>
          <span class="hidden sm:inline">›</span>
          <span class="text-gray-800 font-semibold truncate">{title}</span>
        </div>
        <div class="flex items-center gap-2 sm:gap-3 flex-shrink-0 ml-2">
          {duration && (
            <span class="hidden sm:inline-block text-xs font-medium text-gray-400 bg-gray-100 px-2.5 py-1 rounded-full">
              ⏱ {duration}
            </span>
          )}
          <button
            type="button"
            data-search-open
            class="flex items-center gap-2 text-sm text-gray-400 hover:text-gray-600 border border-gray-200 rounded-lg px-2.5 sm:px-3 py-1.5 transition-colors"
          >
            🔍 <kbd class="text-xs bg-gray-100 border border-gray-200 rounded px-1.5 py-0.5 hidden sm:inline">⌘K</kbd>
          </button>
        </div>
      </header>

      <!-- Lesson body -->
      <article class="max-w-3xl mx-auto px-4 sm:px-6 md:px-8 py-8 md:py-12">
        <!-- Module badge -->
        <div class="mb-4">
          <span
            class="inline-block text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full"
            style={`background-color: ${courseColor}18; color: ${courseColor}`}
          >
            Module {moduleNum} · {moduleTitle}
          </span>
        </div>

        <!-- Title -->
        <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-3 leading-tight">{title}</h1>
        {description && (
          <p class="text-base sm:text-lg text-gray-500 mb-8 leading-relaxed">{description}</p>
        )}

        <!-- YouTube embed -->
        {youtubeId && (
          <div class="mb-10">
            <YouTubeEmbed id={youtubeId} />
          </div>
        )}

        <!-- MDX content -->
        <div class="lesson-prose">
          <slot />
        </div>

        <!-- Prev / Next navigation -->
        <div class="mt-16 pt-8 border-t border-gray-200 flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-3">
          <div id="prev-lesson-nav" class="flex-1"></div>
          <button
            id="complete-btn"
            data-slug={slug}
            class="btn-primary flex-shrink-0 w-full sm:w-auto justify-center"
          >
            ✅ Mark as Complete
          </button>
          <div id="next-lesson-nav" class="flex-1 flex sm:justify-end"></div>
        </div>
      </article>
    </main>
  </div>
</BaseLayout>

<!-- Lightbox overlay -->
<div id="lightbox" role="dialog" aria-modal="true" aria-label="Image preview">
  <button id="lightbox-close" aria-label="Close">&times;</button>
  <img id="lightbox-img" src="" alt="" />
</div>

<script>
  // Lightbox
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxClose = document.getElementById('lightbox-close');

  function openLightbox(src, alt) {
    lightboxImg.src = src;
    lightboxImg.alt = alt || '';
    lightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.lesson-prose img').forEach(img => {
    img.addEventListener('click', () => openLightbox(img.src, img.alt));
  });

  lightboxClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });
</script>

<script define:vars={{ courseLessons: courseLessons.map(l => ({ slug: l.slug, title: l.data.title })), courseSlug, slug, base: import.meta.env.BASE_URL }}>
  const STORAGE_KEY = 'course-progress';

  function getProgress() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch { return {}; }
  }
  function setProgress(p) { localStorage.setItem(STORAGE_KEY, JSON.stringify(p)); }

  // Mark visited
  const completeBtn = document.getElementById('complete-btn');
  if (slug) {
    const progress = getProgress();
    if (!progress[slug]) { progress[slug] = 'visited'; setProgress(progress); }

    // Restore complete state
    if (progress[slug] === 'complete') {
      completeBtn.textContent = '✅ Completed!';
      completeBtn.disabled = true;
      completeBtn.classList.add('opacity-60');
    }

    completeBtn?.addEventListener('click', () => {
      const p = getProgress();
      p[slug] = 'complete';
      setProgress(p);
      document.querySelectorAll(`[data-lesson-slug="${slug}"] .status-icon`).forEach(el => el.textContent = '✅');
      completeBtn.textContent = '✅ Completed!';
      completeBtn.disabled = true;
      completeBtn.classList.add('opacity-60');
    });
  }

  // Build prev/next links
  const currentIdx = courseLessons.findIndex(l => l.slug === slug);
  const prev = courseLessons[currentIdx - 1];
  const next = courseLessons[currentIdx + 1];

  function lessonHref(fullSlug) {
    const lessonSlug = fullSlug.replace(courseSlug + '/', '');
    return `${base}${courseSlug}/lessons/${lessonSlug}`;
  }

  if (prev) {
    document.getElementById('prev-lesson-nav').innerHTML =
      `<a href="${lessonHref(prev.slug)}" class="btn-ghost text-sm w-full sm:w-auto justify-center">← ${prev.title}</a>`;
  }
  if (next) {
    document.getElementById('next-lesson-nav').innerHTML =
      `<a href="${lessonHref(next.slug)}" class="btn-primary text-sm w-full sm:w-auto justify-center">${next.title} →</a>`;
  }

  // Restore all sidebar states
  const allProgress = getProgress();
  document.querySelectorAll('[data-lesson-slug]').forEach(el => {
    const s = el.getAttribute('data-lesson-slug');
    if (s && allProgress[s]) {
      el.setAttribute('data-status', allProgress[s]);
      const icon = el.querySelector('.status-icon');
      if (icon) icon.textContent = allProgress[s] === 'complete' ? '✅' : '📖';
    }
  });
</script>
