---
const base = import.meta.env.BASE_URL;
---
<div id="search-overlay" role="dialog" aria-modal="true" aria-label="Search courses and lessons">
  <div id="search-panel">
    <div id="search-input-row">
      <span id="search-icon">🔍</span>
      <input
        id="search-input"
        type="text"
        placeholder="Search courses and lessons..."
        autocomplete="off"
        spellcheck="false"
      />
      <kbd id="search-esc">esc</kbd>
    </div>
    <div id="search-results"></div>
    <div id="search-empty" hidden>
      <p>No results. Try a different search term.</p>
    </div>
  </div>
</div>

<script define:vars={{ base }}>
  const overlay = document.getElementById('search-overlay');
  const panel = document.getElementById('search-panel');
  const input = document.getElementById('search-input');
  const resultsEl = document.getElementById('search-results');
  const emptyEl = document.getElementById('search-empty');

  let items = null;
  let activeIndex = -1;
  let currentResults = [];

  async function loadIndex() {
    if (items) return items;
    const res = await fetch(`${base}search.json`);
    items = await res.json();
    return items;
  }

  function escapeHtml(str) {
    return str.replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    }[c]));
  }

  function highlight(text, query) {
    const safe = escapeHtml(text);
    if (!query) return safe;
    const idx = safe.toLowerCase().indexOf(query.toLowerCase());
    if (idx === -1) return safe;
    return safe.slice(0, idx) + '<mark>' + safe.slice(idx, idx + query.length) + '</mark>' + safe.slice(idx + query.length);
  }

  function score(item, q) {
    const title = item.title.toLowerCase();
    const desc = (item.description || '').toLowerCase();
    const subtitle = (item.subtitle || '').toLowerCase();
    if (title === q) return 0;
    if (title.startsWith(q)) return 1;
    if (title.includes(q)) return 2;
    if (subtitle.includes(q)) return 3;
    if (desc.includes(q)) return 4;
    return -1;
  }

  function render(results, query) {
    currentResults = results;
    activeIndex = results.length > 0 ? 0 : -1;

    if (results.length === 0) {
      resultsEl.innerHTML = '';
      emptyEl.hidden = query.trim().length === 0;
      return;
    }
    emptyEl.hidden = true;

    resultsEl.innerHTML = results.map((item, i) => `
      <a href="${item.url}" class="search-result" data-index="${i}" data-active="${i === activeIndex}">
        <span class="search-result-icon">${item.icon}</span>
        <span class="search-result-text">
          <span class="search-result-title">${highlight(item.title, query)}</span>
          <span class="search-result-meta">
            <span class="search-result-type">${item.type === 'course' ? 'Course' : 'Lesson'}</span>
            · ${escapeHtml(item.subtitle)}
          </span>
        </span>
      </a>
    `).join('');
  }

  function updateActive() {
    resultsEl.querySelectorAll('.search-result').forEach((el, i) => {
      el.setAttribute('data-active', String(i === activeIndex));
      if (i === activeIndex) el.scrollIntoView({ block: 'nearest' });
    });
  }

  async function handleInput() {
    const q = input.value.trim().toLowerCase();
    if (!q) {
      render([], '');
      return;
    }
    const all = await loadIndex();
    const results = all
      .map(item => ({ item, s: score(item, q) }))
      .filter(({ s }) => s !== -1)
      .sort((a, b) => a.s - b.s)
      .slice(0, 8)
      .map(({ item }) => item);
    render(results, input.value.trim());
  }

  function openSearch() {
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
    input.value = '';
    render([], '');
    loadIndex();
    setTimeout(() => input.focus(), 0);
  }

  function closeSearch() {
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  document.addEventListener('click', (e) => {
    const trigger = e.target.closest('[data-search-open]');
    if (trigger) {
      e.preventDefault();
      openSearch();
    }
  });

  document.addEventListener('keydown', (e) => {
    const isOpen = overlay.classList.contains('open');
    const metaK = (e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k';

    if (metaK) {
      e.preventDefault();
      isOpen ? closeSearch() : openSearch();
      return;
    }

    if (!isOpen) {
      if (e.key === '/' && document.activeElement.tagName !== 'INPUT') {
        e.preventDefault();
        openSearch();
      }
      return;
    }

    if (e.key === 'Escape') {
      closeSearch();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (activeIndex < currentResults.length - 1) { activeIndex++; updateActive(); }
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (activeIndex > 0) { activeIndex--; updateActive(); }
    } else if (e.key === 'Enter') {
      const active = currentResults[activeIndex];
      if (active) window.location.href = active.url;
    }
  });

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeSearch();
  });

  input.addEventListener('input', handleInput);
</script>

<style is:global>
  #search-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(15, 17, 26, 0.5);
    backdrop-filter: blur(3px);
    align-items: flex-start;
    justify-content: center;
    padding: 12vh 1.25rem 1.25rem;
  }
  #search-overlay.open { display: flex; }

  #search-panel {
    width: 100%;
    max-width: 34rem;
    background: white;
    border-radius: 1rem;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.35);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 70vh;
  }

  #search-input-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid #e5e7eb;
    flex-shrink: 0;
  }
  #search-icon { font-size: 1rem; opacity: 0.6; }
  #search-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1rem;
    font-family: inherit;
    color: #1f2937;
    background: transparent;
  }
  #search-input::placeholder { color: #9ca3af; }
  #search-esc {
    font-size: 0.6875rem;
    font-family: inherit;
    color: #9ca3af;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 0.375rem;
    padding: 0.125rem 0.375rem;
  }

  #search-results {
    overflow-y: auto;
    padding: 0.5rem;
  }

  .search-result {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.625rem;
    text-decoration: none;
    color: inherit;
  }
  .search-result[data-active="true"] {
    background: #f0f4ff;
  }
  .search-result-icon { font-size: 1.25rem; line-height: 1.5rem; flex-shrink: 0; }
  .search-result-text { display: flex; flex-direction: column; min-width: 0; }
  .search-result-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #111827;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .search-result-title mark {
    background: #dbe4ff;
    color: #1c38c4;
    border-radius: 0.2rem;
  }
  .search-result-meta {
    font-size: 0.75rem;
    color: #9ca3af;
    margin-top: 0.125rem;
  }
  .search-result-type {
    font-weight: 600;
    color: #6b7280;
  }

  #search-empty {
    padding: 2rem 1.25rem;
    text-align: center;
    color: #9ca3af;
    font-size: 0.875rem;
  }
</style>
