---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  allLessons: CollectionEntry<'lessons'>[];
  currentSlug: string;
}

const { allLessons, currentSlug } = Astro.props;
const base = import.meta.env.BASE_URL;

// Group lessons by module, sorted
const modules = allLessons
  .sort((a, b) => a.data.module - b.data.module || a.data.lesson - b.data.lesson)
  .reduce<Record<number, { title: string; lessons: CollectionEntry<'lessons'>[] }>>(
    (acc, entry) => {
      const m = entry.data.module;
      if (!acc[m]) acc[m] = { title: entry.data.moduleTitle, lessons: [] };
      acc[m].lessons.push(entry);
      return acc;
    },
    {}
  );
---

<aside class="w-72 flex-shrink-0 h-screen overflow-y-auto bg-white border-r border-gray-200 flex flex-col">

  <!-- Logo / course name -->
  <div class="px-5 py-5 border-b border-gray-100">
    <a href={base} class="flex items-center gap-2 group">
      <div class="w-8 h-8 rounded-lg bg-brand-600 flex items-center justify-center text-white font-bold text-sm flex-shrink-0">
        C
      </div>
      <span class="font-bold text-gray-900 text-sm group-hover:text-brand-600 transition-colors">
        Course Platform
      </span>
    </a>
  </div>

  <!-- Progress summary -->
  <div class="px-5 py-4 border-b border-gray-100">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Your Progress</span>
      <span id="progress-label" class="text-xs font-bold text-brand-600">0%</span>
    </div>
    <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
      <div id="progress-bar" class="h-full bg-brand-500 rounded-full transition-all duration-500" style="width: 0%"></div>
    </div>
  </div>

  <!-- Module navigation -->
  <nav class="flex-1 px-3 py-4 space-y-6">
    {Object.entries(modules).map(([modNum, mod]) => (
      <div>
        <!-- Module header -->
        <div class="px-3 mb-2">
          <p class="text-xs font-bold uppercase tracking-widest text-gray-400">
            Module {modNum}
          </p>
          <p class="text-sm font-semibold text-gray-700 mt-0.5">{mod.title}</p>
        </div>

        <!-- Lessons -->
        <ul class="space-y-0.5">
          {mod.lessons.map((entry) => {
            const isActive = entry.slug === currentSlug;
            return (
              <li>
                <a
                  href={`${base}lessons/${entry.slug}`}
                  data-lesson-slug={entry.slug}
                  data-status="locked"
                  class={`nav-lesson ${isActive ? 'active' : ''}`}
                >
                  <span class="status-icon text-base w-5 flex-shrink-0">
                    {isActive ? '📖' : '🔒'}
                  </span>
                  <span class="truncate">{entry.data.title}</span>
                  {entry.data.duration && (
                    <span class="ml-auto text-xs text-gray-400 flex-shrink-0">
                      {entry.data.duration}
                    </span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>

  <!-- Footer -->
  <div class="px-5 py-4 border-t border-gray-100">
    <a href={base} class="text-xs text-gray-400 hover:text-brand-600 transition-colors">
      ← Back to Dashboard
    </a>
  </div>
</aside>

<script>
  // ── Restore progress indicators from localStorage ──
  const STORAGE_KEY = 'course-progress';
  let progress: Record<string, string> = {};
  try {
    progress = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
  } catch {}

  let total = 0;
  let done = 0;

  document.querySelectorAll('[data-lesson-slug]').forEach(el => {
    total++;
    const slug = el.getAttribute('data-lesson-slug')!;
    const state = progress[slug];
    if (state) {
      el.setAttribute('data-status', state);
      const icon = el.querySelector('.status-icon');
      if (icon) {
        icon.textContent = state === 'complete' ? '✅' : '📖';
      }
      if (state === 'complete') done++;
    }
  });

  // Update progress bar
  const pct = total > 0 ? Math.round((done / total) * 100) : 0;
  const bar = document.getElementById('progress-bar');
  const label = document.getElementById('progress-label');
  if (bar) bar.style.width = `${pct}%`;
  if (label) label.textContent = `${pct}%`;
</script>
