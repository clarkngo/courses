---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  courseLessons: CollectionEntry<'lessons'>[];
  currentSlug: string;
  courseSlug: string;
  courseTitle: string;
  courseColor?: string;
}

const {
  courseLessons,
  currentSlug,
  courseSlug,
  courseTitle,
  courseColor = '#3b63f5',
} = Astro.props;

const base = import.meta.env.BASE_URL;

// Group by module
const modules = courseLessons.reduce<Record<number, { title: string; lessons: CollectionEntry<'lessons'>[] }>>(
  (acc, entry) => {
    const m = entry.data.module;
    if (!acc[m]) acc[m] = { title: entry.data.moduleTitle, lessons: [] };
    acc[m].lessons.push(entry);
    return acc;
  },
  {}
);

function lessonHref(fullSlug: string) {
  const lessonSlug = fullSlug.replace(courseSlug + '/', '');
  return `${base}${courseSlug}/lessons/${lessonSlug}`;
}
---

<!-- Mobile backdrop -->
<div id="sidebar-backdrop" class="hidden fixed inset-0 bg-black/40 z-30 md:hidden"></div>

<!-- Invisible strip along the left edge: hovering it peeks open a collapsed sidebar -->
<div id="sidebar-hover-zone" class="hidden md:block fixed inset-y-0 left-0 w-3 z-30" aria-hidden="true"></div>

<!-- Floating handle to re-expand (pin open) a collapsed desktop sidebar -->
<button
  type="button"
  id="sidebar-expand"
  class="hidden fixed left-0 top-20 z-40 items-center justify-center w-6 h-12 rounded-r-lg
         bg-white border border-l-0 border-gray-200 text-gray-400 shadow-sm
         hover:text-brand-600 hover:bg-gray-50 transition-colors"
  aria-label="Expand sidebar"
  title="Expand sidebar"
>
  ›
</button>

<aside
  id="course-sidebar"
  class="w-72 max-w-[85vw] flex-shrink-0 h-screen overflow-y-auto overflow-x-hidden bg-white border-r border-gray-200 flex flex-col
         fixed inset-y-0 left-0 z-40 -translate-x-full transition-transform duration-200 ease-in-out
         md:static md:z-auto md:translate-x-0 md:transition-[width,opacity]"
>

  <!-- Course header -->
  <div class="px-5 py-5 border-b border-gray-100">
    <div class="flex items-center justify-between mb-3">
      <a href={base} class="text-xs text-gray-400 hover:text-brand-600 transition-colors">
        ← All Courses
      </a>
      <div class="flex items-center gap-1">
        <button
          type="button"
          id="sidebar-collapse"
          class="hidden md:flex -mr-1.5 p-1.5 text-gray-400 hover:text-gray-700 rounded-lg hover:bg-gray-100"
          aria-label="Collapse sidebar"
          title="Collapse sidebar"
        >
          ‹
        </button>
        <button
          type="button"
          id="sidebar-close"
          class="md:hidden -mr-1.5 p-1.5 text-gray-400 hover:text-gray-700 rounded-lg hover:bg-gray-100"
          aria-label="Close menu"
        >
          ✕
        </button>
      </div>
    </div>
    <a href={`${base}${courseSlug}/`} class="flex items-center gap-2 group">
      <div
        class="w-8 h-8 rounded-lg flex items-center justify-center text-white font-bold text-sm flex-shrink-0"
        style={`background-color: ${courseColor}`}
      >
        {courseTitle.charAt(0)}
      </div>
      <span class="font-bold text-gray-900 text-sm group-hover:text-brand-600 transition-colors leading-tight">
        {courseTitle}
      </span>
    </a>
  </div>

  <!-- Progress summary -->
  <div class="px-5 py-4 border-b border-gray-100">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Your Progress</span>
      <span id="progress-label" class="text-xs font-bold" style={`color: ${courseColor}`}>0%</span>
    </div>
    <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
      <div
        id="progress-bar"
        class="h-full rounded-full transition-all duration-500"
        style={`width: 0%; background-color: ${courseColor}`}
      ></div>
    </div>
  </div>

  <!-- Module navigation -->
  <nav class="flex-1 px-3 py-4 space-y-6">
    {Object.entries(modules).map(([modNum, mod]) => (
      <div>
        <div class="px-3 mb-2">
          <p class="text-xs font-bold uppercase tracking-widest text-gray-400">Module {modNum}</p>
          <p class="text-sm font-semibold text-gray-700 mt-0.5">{mod.title}</p>
        </div>

        <ul class="space-y-0.5">
          {mod.lessons.map((entry) => {
            const isActive = entry.slug === currentSlug;
            return (
              <li>
                <a
                  href={lessonHref(entry.slug)}
                  data-lesson-slug={entry.slug}
                  data-status="locked"
                  class={`nav-lesson ${isActive ? 'active' : ''}`}
                >
                  <span class="status-icon text-base w-5 flex-shrink-0">
                    {isActive ? '📖' : '🔒'}
                  </span>
                  <span class="truncate">{entry.data.title}</span>
                  {entry.data.duration && (
                    <span class="ml-auto text-xs text-gray-400 flex-shrink-0">{entry.data.duration}</span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>

  <!-- Footer -->
  <div class="px-5 py-4 border-t border-gray-100">
    <a href={`${base}${courseSlug}/`} class="text-xs text-gray-400 hover:text-brand-600 transition-colors">
      ← Course Overview
    </a>
  </div>
</aside>

<style>
  @media (min-width: 768px) {
    #course-sidebar.is-collapsed {
      width: 0;
      opacity: 0;
      pointer-events: none;
    }
    #course-sidebar.is-collapsed.is-hover-peek {
      position: fixed;
      inset-block: 0;
      left: 0;
      width: 18rem;
      opacity: 1;
      pointer-events: auto;
      box-shadow: 0 20px 40px -8px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(0, 0, 0, 0.05);
    }
  }
</style>

<script>
  const STORAGE_KEY = 'course-progress';
  let progress: Record<string, string> = {};
  try { progress = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch {}

  let total = 0;
  let done = 0;

  document.querySelectorAll('[data-lesson-slug]').forEach(el => {
    total++;
    const slug = el.getAttribute('data-lesson-slug')!;
    const state = progress[slug];
    if (state) {
      el.setAttribute('data-status', state);
      const icon = el.querySelector('.status-icon');
      if (icon) icon.textContent = state === 'complete' ? '✅' : '📖';
      if (state === 'complete') done++;
    }
  });

  const pct = total > 0 ? Math.round((done / total) * 100) : 0;
  const bar = document.getElementById('progress-bar');
  const label = document.getElementById('progress-label');
  if (bar) bar.style.width = `${pct}%`;
  if (label) label.textContent = `${pct}%`;
</script>

<script>
  const sidebar = document.getElementById('course-sidebar');
  const backdrop = document.getElementById('sidebar-backdrop');
  const toggleBtn = document.getElementById('sidebar-toggle');
  const closeBtn = document.getElementById('sidebar-close');
  const collapseBtn = document.getElementById('sidebar-collapse');
  const expandBtn = document.getElementById('sidebar-expand');
  const hoverZone = document.getElementById('sidebar-hover-zone');

  function openSidebar() {
    sidebar?.classList.remove('-translate-x-full');
    backdrop?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    sidebar?.classList.add('-translate-x-full');
    backdrop?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  toggleBtn?.addEventListener('click', openSidebar);
  closeBtn?.addEventListener('click', closeSidebar);
  backdrop?.addEventListener('click', closeSidebar);

  sidebar?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      if (window.innerWidth < 768) closeSidebar();
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSidebar();
  });

  // Desktop collapse/expand (persisted across pages). Defaults to collapsed;
  // hovering the left edge peeks the sidebar open without changing the pinned state.
  const COLLAPSE_KEY = 'course-sidebar-collapsed';
  let collapsed = true;
  try {
    const stored = localStorage.getItem(COLLAPSE_KEY);
    collapsed = stored === null ? true : stored === '1';
  } catch {}

  function updateA11y() {
    const visible = !collapsed || sidebar?.classList.contains('is-hover-peek');
    sidebar?.setAttribute('aria-hidden', visible ? 'false' : 'true');
  }

  function setCollapsed(value: boolean) {
    collapsed = value;
    try { localStorage.setItem(COLLAPSE_KEY, value ? '1' : '0'); } catch {}
    sidebar?.classList.toggle('is-collapsed', value);
    if (!value) sidebar?.classList.remove('is-hover-peek');
    collapseBtn?.setAttribute('aria-expanded', String(!value));
    expandBtn?.classList.toggle('md:flex', value);
    updateA11y();
  }

  function setHoverPeek(value: boolean) {
    if (!collapsed) return;
    sidebar?.classList.toggle('is-hover-peek', value);
    updateA11y();
  }

  sidebar?.classList.toggle('is-collapsed', collapsed);
  expandBtn?.classList.toggle('md:flex', collapsed);
  collapseBtn?.setAttribute('aria-expanded', String(!collapsed));
  updateA11y();

  collapseBtn?.addEventListener('click', () => setCollapsed(true));
  expandBtn?.addEventListener('click', () => setCollapsed(false));

  let peekLeaveTimer: ReturnType<typeof setTimeout>;
  function peekIn() {
    clearTimeout(peekLeaveTimer);
    setHoverPeek(true);
  }
  function peekOut() {
    clearTimeout(peekLeaveTimer);
    peekLeaveTimer = setTimeout(() => setHoverPeek(false), 150);
  }

  hoverZone?.addEventListener('mouseenter', peekIn);
  sidebar?.addEventListener('mouseenter', peekIn);
  hoverZone?.addEventListener('mouseleave', peekOut);
  sidebar?.addEventListener('mouseleave', peekOut);
</script>
